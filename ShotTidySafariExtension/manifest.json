{
    "manifest_version": 3,
    "name": "ShotTidier",
    "version": "1.0",
    "description": "Save selected text into your ShotTidier catalog.",

    "background": {
        "scripts": ["background.js"],
        "persistent": false
    },

    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "css": ["content.css"]
        }
    ],

    "permissions": ["nativeMessaging"]
}
