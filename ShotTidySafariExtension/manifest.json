{
    "manifest_version": 3,
    "name": "ShotTidier",
    "version": "1.0",
    "description": "Save selected text into your ShotTidier catalog.",

    "icons": {
        "48": "icon-48.png",
        "64": "icon-64.png",
        "96": "icon-96.png",
        "128": "icon-128.png",
        "256": "icon-256.png",
        "512": "icon-512.png"
    },

    "background": {
        "scripts": ["background.js"],
        "persistent": false
    },

    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "css": ["content.css"]
        }
    ],

    "permissions": ["nativeMessaging"]
}
