            "value": "Kein Anreicherungs-Guthaben mehr übrig. Öffne ShotTidier, um mehr zu kaufen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No quedan créditos de enriquecimiento. Abre ShotTidier para comprar más."
          }
