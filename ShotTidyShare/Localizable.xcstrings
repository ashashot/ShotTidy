        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous avez utilisé vos %lld analyses gratuites de captures d'écran pour cette période de 30 jours."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "translated",
            "value": "Դուք օգտագործել եք բոլոր %lld անվճար սքրինշոթների վերլուծությունները այս 30-օրյա ժամանակահատվածի համար։"
