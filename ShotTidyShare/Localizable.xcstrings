    "Open ShotTidier → Settings to upgrade to Pro for unlimited analyses.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Öffne ShotTidier → Einstellungen, um auf Pro upzugraden und unbegrenzte Analysen zu erhalten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Abre ShotTidier → Ajustes para mejorar a Pro y tener análisis ilimitados."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ouvrez ShotTidier → Réglages pour passer à Pro et bénéficier d'analyses illimitées."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "translated",
            "value": "Բացեք ShotTidier → Կարգավորումներ՝ Pro-ի անցնելու համար՝ անսահմանափակ վերլուծությունների նպատակով։"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Apri ShotTidier → Impostazioni per passare a Pro e avere analisi illimitate."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ShotTidier →設定を開いてProにアップグレードすると、無制限に解析できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "ShotTidier → 설정을 열어 Pro로 업그레이드하면 무제한으로 분석할 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Abra ShotTidier → Configurações para fazer upgrade para o Pro e ter análises ilimitadas."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Abra ShotTidier → Definições para fazer upgrade para o Pro e ter análises ilimitadas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Откройте ShotTidier → Настройки, чтобы перейти на Pro для неограниченных анализов."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sınırsız analiz için ShotTidier → Ayarlar'dan Pro'ya yükseltin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
