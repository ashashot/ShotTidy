            "value": "Du hast alle %lld kostenlosen Screenshot-Analysen für diesen 30-Tage-Zeitraum aufgebraucht."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Has usado tus %lld análisis gratuitos de capturas para este periodo de 30 días."
