    "A new version of ShotTidier is available.\nPlease update the app to continue using it.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine neue Version von ShotTidier ist verfügbar.\nBitte aktualisiere die App, um sie weiter zu nutzen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hay una nueva versión de ShotTidier disponible.\nActualiza la app para seguir usándola."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une nouvelle version de ShotTidier est disponible.\nMettez à jour l'application pour continuer à l'utiliser."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "translated",
            "value": "ShotTidier-ի նոր տարբերակը հասանելի է։\nԽնդրում ենք թարմացնել հավելվածը՝ շարունակելու համար։"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "È disponibile una nuova versione di ShotTidier.\nAggiorna l'app per continuare a usarla."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ShotTidierの新しいバージョンが利用可能です。\n引き続きご利用いただくにはアプリをアップデートしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "ShotTidier의 새 버전을 사용할 수 있습니다.\n계속 사용하려면 앱을 업데이트하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Uma nova versão do ShotTidier está disponível.\nAtualize o app para continuar usando."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Está disponível uma nova versão do ShotTidier.\nAtualize a app para continuar a utilizá-la."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Доступна новая версия ShotTidier.\nОбновите приложение, чтобы продолжить пользоваться им."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "ShotTidier'ın yeni bir sürümü mevcut.\nKullanmaya devam etmek için lütfen uygulamayı güncelleyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "ShotTidier 有新版本可用。\n请更新应用以继续使用。"
          }
        }
      }
    },
