    "AI could not analyze this screenshot.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die KI konnte diesen Screenshot nicht analysieren."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La IA no pudo analizar esta captura."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'IA n'a pas pu analyser cette capture d'écran."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "translated",
            "value": "ԱԲ-ն չկարողացավ վերլուծել այս սքրինշոթը։"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'IA non è riuscita ad analizzare questo screenshot."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "AIがこのスクリーンショットを解析できませんでした。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "AI가 이 스크린샷을 분석하지 못했습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A IA não conseguiu analisar esta captura de tela."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "A IA não conseguiu analisar esta captura de ecrã."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "ИИ не смог проанализировать этот скриншот."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yapay zeka bu ekran görüntüsünü analiz edemedi."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "AI 无法分析此截图。"
          }
        }
      }
    },
    "AI couldn't detect any data in this screenshot. Add the item manually.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die KI konnte in diesem Screenshot keine Daten erkennen. Füge das Element manuell hinzu."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La IA no detectó datos en esta captura. Añade el elemento manualmente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'IA n'a détecté aucune donnée dans cette capture d'écran. Ajoutez l'élément manuellement."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "translated",
            "value": "ԱԲ-ն այս սքրինշոթում տվյալներ չհայտնաբերեց։ Ավելացրեք տարրը ձեռքով։"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'IA non ha rilevato dati in questo screenshot. Aggiungi l'elemento manualmente."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "AIがこのスクリーンショットからデータを検出できませんでした。手動で項目を追加してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "AI가 이 스크린샷에서 데이터를 감지하지 못했습니다. 항목을 수동으로 추가하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A IA não detectou nenhum dado nesta captura de tela. Adicione o item manualmente."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "A IA não detetou quaisquer dados nesta captura de ecrã. Adicione o item manualmente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "ИИ не удалось обнаружить данные на этом скриншоте. Добавьте элемент вручную."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yapay zeka bu ekran görüntüsünde herhangi bir veri tespit edemedi. Öğeyi manuel olarak ekleyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "AI 未能在此截图中检测到任何数据。请手动添加项目。"
          }
        }
      }
    },
