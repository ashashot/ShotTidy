    "The App Group shared container is unavailable. Check the group.com.mbx.ShotTidier configuration.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der gemeinsame App Group-Container ist nicht verfügbar. Überprüfe die Konfiguration von group.com.mbx.ShotTidier."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El contenedor compartido del grupo de apps no está disponible. Comprueba la configuración de group.com.mbx.ShotTidier."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le conteneur partagé App Group est indisponible. Vérifiez la configuration de group.com.mbx.ShotTidier."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "translated",
            "value": "App Group ընդհանուր կոնտեյները անհասանելի է։ Ստուգեք group.com.mbx.ShotTidier կազմաձևումը։"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il contenitore condiviso App Group non è disponibile. Controlla la configurazione di group.com.mbx.ShotTidier."
