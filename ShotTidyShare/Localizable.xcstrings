        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Plus de crédits d'enrichissement. Ouvrez ShotTidier pour en acheter d'autres."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "translated",
            "value": "Հարստացման կրեդիտներ չեն մնացել։ Բացեք ShotTidier-ը՝ ավելին գնելու համար։"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nessun credito di arricchimento rimasto. Apri ShotTidier per acquistarne altri."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "補完クレジットが残っていません。ShotTidierを開いて追加購入してください。"
