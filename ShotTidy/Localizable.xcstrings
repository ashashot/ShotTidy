          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Os itens do catálogo associados não serão eliminados."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Связанные элементы каталога не будут удалены."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "İlişkili katalog öğeleri silinmeyecek."
          }
        },
