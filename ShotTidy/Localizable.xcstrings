          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Синхронизация iCloud включена. Перезапустите приложение, чтобы начать синхронизацию каталога между устройствами."
          }
        },
        "tr" : {
          "stringUnit" : {
