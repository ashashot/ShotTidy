    "iCloud sync has been disabled. Please restart the app to apply changes." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die iCloud-Synchronisierung wurde deaktiviert. Starte die App neu, um die Änderungen zu übernehmen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La sincronización con iCloud se ha desactivado. Reinicia la app para aplicar los cambios."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La synchronisation iCloud a été désactivée. Redémarrez l'application pour appliquer les modifications."
          }
        },
        "hy" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud համաժամացումն անջատված է։ Խնդրում ենք վերագործարկել հավելվածը՝ փոփոխությունները կիրառելու համար։"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La sincronizzazione iCloud è stata disattivata. Riavvia l'app per applicare le modifiche."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud同期がオフになりました。変更を適用するにはアプリを再起動してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud 동기화가 비활성화되었습니다. 변경 사항을 적용하려면 앱을 다시 시작하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A sincronização do iCloud foi desativada. Reinicie o app para aplicar as alterações."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A sincronização do iCloud foi desativada. Reinicie a app para aplicar as alterações."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Синхронизация iCloud отключена. Перезапустите приложение, чтобы применить изменения."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud senkronizasyonu devre dışı bırakıldı. Değişiklikleri uygulamak için lütfen uygulamayı yeniden başlatın."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud 同步已停用。请重启应用以应用更改。"
          }
        }
      },
      "extractionState" : "stale"
    },
    "iCloud sync has been disabled. Tap \"Restart Now\" to apply the change." : {
      "comment" : "A message displayed in an alert that tells the user to restart the app to enable iCloud sync.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die iCloud-Synchronisierung wurde deaktiviert. Tippe auf „Jetzt neu starten“, um die Änderung zu übernehmen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La sincronización con iCloud se ha desactivado. Toca «Reiniciar ahora» para aplicar el cambio."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La synchronisation iCloud a été désactivée. Touchez « Redémarrer maintenant » pour appliquer la modification."
          }
        },
        "hy" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud համաժամացումն անջատված է։ Հպեք «Վերագործարկել հիմա»՝ փոփոխությունը կիրառելու համար։"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La sincronizzazione iCloud è stata disattivata. Tocca «Riavvia ora» per applicare la modifica."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud同期がオフになりました。変更を適用するには「今すぐ再起動」をタップしてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud 동기화가 비활성화되었습니다. 변경 사항을 적용하려면 \"지금 다시 시작\"을 탭하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A sincronização do iCloud foi desativada. Toque em \"Reiniciar agora\" para aplicar a alteração."
          }
        },
        "pt-PT" : {
