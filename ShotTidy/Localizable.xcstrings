            "value" : "Դուք դեռ կարող եք պահպանել — կրկնությունները ցուցադրվում են միայն որպես նախազգուշացում։"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Puoi comunque salvare: i duplicati vengono mostrati solo come avviso."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "そのまま保存できます — 重複は警告として表示されるだけです。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "그래도 저장할 수 있습니다 — 중복 항목은 경고로만 표시됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você ainda pode salvar — as duplicatas são exibidas apenas como um aviso."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ainda pode guardar — os duplicados são apresentados apenas como aviso."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы всё равно можете сохранить — дубликаты показаны только как предупреждение."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yine de kaydedebilirsiniz — yinelenenler yalnızca uyarı olarak gösterilir."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您仍然可以保存——重复项仅作为提示显示。"
          }
        }
      }
    },
