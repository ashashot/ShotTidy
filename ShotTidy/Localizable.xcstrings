        },
        "hy" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud համաժամացումը միացված է։ Խնդրում ենք վերագործարկել հավելվածը՝ ձեր կատալոգը սարքերի միջև համաժամացնելու համար։"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
