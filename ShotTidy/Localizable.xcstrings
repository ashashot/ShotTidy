    "Screenshots appear here once you save\ncatalog items extracted from them." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Screenshots erscheinen hier, sobald du daraus\nextrahierte Katalogeinträge speicherst."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las capturas aparecerán aquí en cuanto guardes\nelementos del catálogo extraídos de ellas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les captures d'écran apparaîtront ici dès que vous enregistrerez\ndes éléments du catalogue qui en sont extraits."
          }
        },
        "hy" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Սքրինշոթները հայտնվում են այստեղ, երբ դուք պահպանում եք\nդրանցից արտահանված կատալոգի տարրերը։"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gli screenshot appariranno qui non appena salverai\ngli elementi del catalogo estratti da essi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "スクリーンショットから抽出したカタログ項目を保存すると、\nここに表示されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "스크린샷에서 추출한 카탈로그 항목을 저장하면\n여기에 표시됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As capturas de tela aparecem aqui assim que você salvar\nitens do catálogo extraídos delas."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As capturas de ecrã aparecem aqui assim que guardar\nitens do catálogo extraídos delas."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Скриншоты появятся здесь, как только вы сохраните\nизвлечённые из них элементы каталога."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekran görüntüleri, onlardan çıkarılan katalog öğelerini\nkaydettiğinizde burada görünür."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "保存从截图中提取的目录项目后，\n截图会显示在这里。"
          }
        }
      }
    },
