    "Items in this category will be kept but shown under “%@”. This cannot be undone." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elemente dieser Kategorie bleiben erhalten, werden aber unter „%@“ angezeigt. Dies kann nicht rückgängig gemacht werden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los elementos de esta categoría se conservarán, pero se mostrarán bajo “%@”. Esta acción no se puede deshacer."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les éléments de cette catégorie seront conservés, mais affichés sous « %@ ». Cette action est irréversible."
          }
        },
        "hy" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Այս կատեգորիայի տարրերը կպահպանվեն, բայց կցուցադրվեն «%@» անվան տակ։ Այս գործողությունը հնարավոր չէ հետարկել։"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gli elementi di questa categoria verranno mantenuti, ma mostrati sotto “%@”. Questa azione non può essere annullata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このカテゴリーの項目は保持されますが、「%@」として表示されます。この操作は元に戻せません。"
          }
        },
