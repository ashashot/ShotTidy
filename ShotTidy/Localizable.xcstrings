    "The associated catalog items will not be deleted." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die zugehörigen Katalogeinträge werden nicht gelöscht."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los elementos del catálogo asociados no se eliminarán."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les éléments du catalogue associés ne seront pas supprimés."
          }
        },
        "hy" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Կապակցված կատալոգի տարրերը չեն ջնջվի։"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gli elementi del catalogo associati non verranno eliminati."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "関連するカタログ項目は削除されません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "연결된 카탈로그 항목은 삭제되지 않습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
