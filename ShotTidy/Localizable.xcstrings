      }
    },
    "The screenshot backup will be removed. Catalog items extracted from it will not be affected." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Screenshot-Sicherung wird entfernt. Daraus extrahierte Katalogeinträge sind davon nicht betroffen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se eliminará la copia de seguridad de la captura. Los elementos del catálogo extraídos de ella no se verán afectados."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La sauvegarde de la capture d'écran sera supprimée. Les éléments du catalogue qui en sont extraits ne seront pas affectés."
          }
        },
        "hy" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Սքրինշոթի պահուստային պատճենը կհեռացվի։ Դրանից արտահանված կատալոգի տարրերի վրա դա չի ազդի։"
          }
        },
        "it" : {
          "stringUnit" : {
