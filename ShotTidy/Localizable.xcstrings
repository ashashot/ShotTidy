    "Analyze unlimited screenshots and get\nenrichment credits every month." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Analysiere unbegrenzt Screenshots und erhalte\njeden Monat Anreicherungs-Guthaben."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Analiza capturas ilimitadas y obtén\ncréditos de enriquecimiento cada mes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Analysez un nombre illimité de captures d'écran et obtenez\ndes crédits d'enrichissement chaque mois."
          }
        },
        "hy" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Վերլուծեք անսահմանափակ սքրինշոթներ և ստացեք\nհարստացման կրեդիտներ ամեն ամիս։"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Analizza screenshot illimitati e ottieni\ncrediti di arricchimento ogni mese."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "スクリーンショットを無制限に解析し、\n毎月補完クレジットを獲得できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "무제한으로 스크린샷을 분석하고\n매달 보강 크레딧을 받으세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
